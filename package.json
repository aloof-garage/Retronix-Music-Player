{
  "name": "retronix-music-player",
  "version": "1.0.0",
  "description": "Retronix MK·II — A skeuomorphic desktop music player",
  "main": "src/main/index.js",
  "author": "Retronix Audio",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "music-metadata": "^7.14.0",
    "glob": "^10.3.10",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.6"
  },
  "build": {
    "appId": "com.retronix.musicplayer",
    "productName": "Retronix Music Player",
    "directories": { "buildResources": "resources", "output": "dist" },
    "files": ["out/**/*"],
    "win":   { "target": ["nsis", "portable"] },
    "mac":   { "target": ["dmg", "zip"] },
    "linux": { "target": ["AppImage", "deb"] },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true },
    "fileAssociations": [
      { "ext": "mp3",  "name": "MP3 Audio",  "role": "Viewer" },
      { "ext": "flac", "name": "FLAC Audio", "role": "Viewer" },
      { "ext": "wav",  "name": "WAV Audio",  "role": "Viewer" },
      { "ext": "m4a",  "name": "M4A Audio",  "role": "Viewer" },
      { "ext": "aac",  "name": "AAC Audio",  "role": "Viewer" },
      { "ext": "ogg",  "name": "OGG Audio",  "role": "Viewer" }
    ]
  }
}
